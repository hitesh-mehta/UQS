# ═══════════════════════════════════════════════════════════════
#  Universal Query Solver (UQS) — Environment Variables Template
#  Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres

# ── LLM Provider ──────────────────────────────────────────────
# Options: ollama | openai | anthropic | google
LLM_PROVIDER=ollama

# Model name (depends on provider):
#   Ollama:    gemma2:2b | gemma2:9b | mistral | llama3.2
#   OpenAI:    gpt-4o-mini | gpt-4o
#   Anthropic: claude-3-haiku-20240307
LLM_MODEL=gemma2:2b

# Ollama base URL (only needed if LLM_PROVIDER=ollama)
LLM_BASE_URL=http://localhost:11434

# OpenAI API key (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API key (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Authentication ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-this-to-a-very-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Cache Layer ───────────────────────────────────────────────
# Local filesystem path for report cache storage
CACHE_STORE_PATH=./cache_store
# Number of units to retain per granularity level (fifo eviction)
CACHE_RETENTION_UNITS=10

# ── ML Model Registry ─────────────────────────────────────────
MODEL_REGISTRY_PATH=./model_registry
MAX_ROLLBACK_VERSIONS=5

# ── Vector Store ──────────────────────────────────────────────
# Options: faiss | qdrant
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=./faiss_index

# Qdrant settings (only needed if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Cron Jobs ─────────────────────────────────────────────────
# Enable background cron-based cache refresh and model retraining
CRON_ENABLED=false
CRON_CACHE_HOURLY=0 * * * *
CRON_CACHE_DAILY=0 2 * * *
CRON_CACHE_WEEKLY=0 3 * * 0
CRON_CACHE_MONTHLY=0 4 1 * *
CRON_MODEL_RETRAIN=0 5 * * *
